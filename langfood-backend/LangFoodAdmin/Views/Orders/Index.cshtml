@model IEnumerable<LangFood.Shared.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Danh sách Đơn hàng</h1>
</div>

<div class="admin-card shadow mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <h6 class="m-0 font-weight-bold" style="color: var(--accent-color);">Tất cả Đơn hàng</h6>
        
        <!-- Bộ lọc -->
        <form method="get" asp-action="Index" class="d-flex align-items-center gap-2">
            <label for="dormFilter" class="fw-bold mb-0 text-nowrap">Lọc theo KTX:</label>
            <select id="dormFilter" name="buildingId" class="form-select form-select-sm" style="width: auto;" asp-items="@ViewBag.BuildingList">
                <option value="">-- Tất cả tòa nhà --</option>
            </select>
            
            <button type="submit" class="btn btn-sm btn-primary ms-2"><i class="fas fa-filter"></i> Lọc</button>
        </form>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Mã đơn</th>
                    <th>Ngày đặt</th>
                    <th>Khách hàng</th>
                    <th>Tòa nhà KTX</th>
                    <th>Cửa hàng</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var order in Model)
                    {
                        <tr>
                            <td class="fw-bold">#LF-@order.Id.ToString("D3")</td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(order.BuyerName ?? "Khách vãng lai")</td>
                            <td>
                                @if (order.Building != null)
                                {
                                    <span class="badge bg-secondary">@order.Building.Name</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border">@order.DeliveryBuilding</span>
                                }
                            </td>
                            <td>@(order.Shop?.Name ?? "N/A")</td>
                            <td class="fw-bold text-danger">@order.TotalAmount.ToString("N0")₫</td>
                            <td>
                                @switch (order.Status)
                                {
                                    case "Pending":
                                        <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                        break;
                                    case "Shipping":
                                        <span class="badge bg-info text-dark">Đang giao</span>
                                        break;
                                    case "Completed":
                                        <span class="badge bg-success">Đã giao</span>
                                        break;
                                    case "Cancelled":
                                        <span class="badge bg-danger">Đã hủy</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@order.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info text-white" title="Chi tiết"><i class="fas fa-eye"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">Không tìm thấy đơn hàng nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Phân trang (Tạm thời để tĩnh) -->
    <div class="d-flex justify-content-end mt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1" aria-disabled="true">Trang trước</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">Trang sau</a></li>
            </ul>
        </nav>
    </div>
</div>

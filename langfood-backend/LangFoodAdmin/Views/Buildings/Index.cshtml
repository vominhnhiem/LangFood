@model IEnumerable<LangFood.Shared.Models.Building>

<div class="container-fluid shadow-sm p-3 mb-5 bg-white rounded">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Quản lý tòa nhà KTX</h3>
        <a asp-action="Create" class="btn btn-primary">Thêm tòa mới</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-hover">
        <thead class="thead-dark">
            <tr>
                <th>ID</th>
                <th>Tên tòa nhà</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@(item.IsActive ? "Hoạt động" : "Tạm khóa")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Mày chắc chắn muốn xóa tòa này không?')">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
razor
@model LangFood.Shared.Models.Building

@{
    ViewData["Title"] = "Thêm tòa nhà mới";
}

<div class="row mt-4">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Thêm tòa nhà KTX mới</h4>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label">Tên tòa nhà (ví dụ: Tòa A1)</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên tòa..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3 form-check">
                        <label class="form-check-label">
                            <input class="form-check-input" asp-for="IsActive" /> @Html.DisplayNameFor(model => model.IsActive) (Đang hoạt động)
                        </label>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Lưu lại
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
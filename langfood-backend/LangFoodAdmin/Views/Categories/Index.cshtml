@model IEnumerable<LangFood.Shared.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Quản lý Danh mục</h1>
    <a asp-action="Create" class="btn text-white px-4 fw-bold shadow-sm" style="background-color: #F24E1E;">
        <i class="fas fa-plus me-2"></i>Thêm danh mục mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
    </div>
}

<div class="admin-card shadow-sm border-0" style="border-radius: 12px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4" style="width: 100px;">Ảnh</th>
                    <th>Tên danh mục</th>
                    <th class="text-center">Số món ăn</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @{
                                    var imgSrc = string.IsNullOrEmpty(item.ImageUrl) 
                                        ? "http://localhost:5289/images/categories/default.png" 
                                        : (item.ImageUrl.StartsWith("http") ? item.ImageUrl : "http://localhost:5289/" + item.ImageUrl);
                                }
                                <img src="@imgSrc"
                                     class="rounded shadow-sm border"
                                     style="width: 60px; height: 60px; object-fit: cover;"
                                     alt="@item.Name" />
                            </td>
                            <td>
                                <div class="fw-bold text-dark fs-5">@item.Name</div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border px-3 py-2 rounded-pill">
                                    <i class="fas fa-utensils me-1 text-muted"></i> @(item.Products?.Count ?? 0)
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light rounded-circle p-2 text-warning shadow-sm" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light rounded-circle p-2 text-danger shadow-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này? Các sản phẩm thuộc danh mục cũng sẽ bị ẩn.')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted italic">Chưa có danh mục nào được tạo.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .admin-card {
        background: #fff;
        overflow: hidden;
    }
    .table thead th {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        color: #6c757d;
        border-bottom: 1px solid #eee;
        padding-top: 15px;
        padding-bottom: 15px;
    }
    .table tbody tr:hover {
        background-color: #fafafa;
    }
</style>
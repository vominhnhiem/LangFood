@model LangFood.Shared.Models.Category
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 mx-auto" style="border-radius: 16px; max-width: 800px;">
        <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
            <h3 class="fw-bold text-dark mb-0">
                <i class="fas fa-edit me-2 text-warning"></i>Chỉnh sửa danh mục
            </h3>
            <p class="text-muted small mt-1">Cập nhật thông tin và hình ảnh đại diện cho danh mục món ăn.</p>
        </div>
        
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                
                <div class="row g-4">
                    <!-- Preview Ảnh -->
                    <div class="col-md-4 text-center border-end d-flex flex-column align-items-center justify-content-center">
                        <label class="fw-bold small text-muted text-uppercase mb-3 d-block">Ảnh hiện tại</label>
                        <div class="position-relative">
                            @{
                                var imgSrc = string.IsNullOrEmpty(Model.ImageUrl) 
                                    ? "http://localhost:5289/images/categories/default.png" 
                                    : (Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : "http://localhost:5289/" + Model.ImageUrl);
                            }
                            <img id="previewImg" src="@imgSrc" 
                                 class="shadow-sm border rounded-3 mb-3" 
                                 style="width: 180px; height: 180px; object-fit: cover;">
                            <div class="badge bg-dark position-absolute bottom-0 start-50 translate-middle-x mb-4 shadow">Preview</div>
                        </div>
                    </div>

                    <!-- Form nhập liệu -->
                    <div class="col-md-8 px-md-4">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark"><i class="fas fa-tag me-1 text-muted"></i> Tên danh mục</label>
                            <input asp-for="Name" class="form-control form-control-lg border-0 bg-light" placeholder="Ví dụ: Cơm trưa, Đồ uống..." required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark"><i class="fas fa-image me-1 text-muted"></i> Thay đổi ảnh đại diện</label>
                            <div class="input-group">
                                <input type="file" name="imageFile" id="imageFile" class="form-control border-0 bg-light" accept="image/*">
                            </div>
                            <div class="form-text mt-2 small text-muted">
                                <i class="fas fa-info-circle me-1"></i> Định dạng: JPG, PNG, WebP. Để trống nếu không muốn thay đổi ảnh.
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-3">
                            <button type="submit" class="btn btn-lg text-white px-4 fw-bold shadow-sm" style="background-color: #F24E1E;">
                                <i class="fas fa-save me-2"></i>Lưu thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-lg btn-light border px-4 fw-bold text-secondary shadow-sm">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiển thị preview ảnh ngay khi chọn file
        document.getElementById('imageFile').onchange = function (evt) {
            var tgt = evt.target || window.event.srcElement,
                files = tgt.files;

            if (FileReader && files && files.length) {
                var fr = new FileReader();
                fr.onload = function () {
                    document.getElementById('previewImg').src = fr.result;
                }
                fr.readAsDataURL(files[0]);
            }
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-control:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(242, 78, 30, 0.15);
        border: 1px solid #F24E1E !important;
    }
    .btn-light:hover {
        background-color: #f8f9fa;
        color: #333 !important;
    }
</style>
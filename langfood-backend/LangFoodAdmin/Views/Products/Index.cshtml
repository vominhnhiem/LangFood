@model LangFood.Shared.ViewModels.ProductManagementViewModel
@{
    ViewData["Title"] = "Quản lý Món ăn";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Quản lý Món ăn</h1>
</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4">
        <i class="fas fa-check-circle me-2"></i>@TempData["Msg"]
    </div>
}

<!-- Tabs Control -->
<ul class="nav nav-tabs border-bottom-0 mb-3" id="productTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold px-4 py-2 position-relative" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
            Món ăn chờ duyệt
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                @Model.PendingProducts.Count
            </span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold px-4 py-2" id="active-tab" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
            Menu đang hoạt động
        </button>
    </li>
</ul>

<div class="tab-content" id="productTabsContent">
    <!-- TAB 1: CHỜ DUYỆT -->
    <div class="tab-pane fade show active" id="pending" role="tabpanel" aria-labelledby="pending-tab">
        <div class="admin-card shadow-sm border-0" style="border-radius: 0 0 12px 12px;">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Hình ảnh</th>
                            <th>Thông tin món</th>
                            <th>Giá bán</th>
                            <th>Quán ăn</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PendingProducts != null && Model.PendingProducts.Any())
                        {
                            foreach (var item in Model.PendingProducts)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="product-thumb-container">
                                            <img src="http://localhost:5289/@item.ImageUrl" class="product-thumb rounded shadow-sm view-image" data-img="http://localhost:5289/@item.ImageUrl" />
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Name</div>
                                        <div class="small text-muted">@item.Category?.Name</div>
                                    </td>
                                    <td class="fw-bold text-danger">@item.Price.ToString("N0")₫</td>
                                    <td>
                                        <span class="badge bg-light text-dark border"><i class="fas fa-store me-1 text-secondary"></i> @(item.Shop?.Name ?? "N/A")</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-light rounded-circle p-2 text-primary shadow-sm" title="Chi tiết"><i class="fas fa-eye"></i></button>
                                            <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-light rounded-circle p-2 text-success shadow-sm" title="Phê duyệt"><i class="fas fa-check"></i></a>
                                            <button class="btn btn-sm btn-light rounded-circle p-2 text-danger shadow-sm btn-reject-product" data-id="@item.Id" title="Từ chối"><i class="fas fa-times"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted italic">Hiện không có món ăn nào chờ duyệt.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- TAB 2: ĐANG HOẠT ĐỘNG -->
    <div class="tab-pane fade" id="active" role="tabpanel" aria-labelledby="active-tab">
        <div class="admin-card shadow-sm border-0" style="border-radius: 0 0 12px 12px;">
            <!-- Bộ lọc -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" id="searchProductName" class="form-control border-start-0" placeholder="Tìm tên món ăn...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select id="filterShop" class="form-select form-select-sm">
                        <option value="">-- Tất cả Quán ăn --</option>
                        @foreach (var shop in Model.Shops)
                        {
                            <option value="@shop.Name">@shop.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="filterCategory" class="form-select form-select-sm">
                        <option value="">-- Tất cả Danh mục --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Name">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 text-end">
                    <button id="btnFilter" class="btn btn-sm btn-secondary w-100 fw-bold"><i class="fas fa-filter me-1"></i> Lọc</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Hình ảnh</th>
                            <th>Thông tin món</th>
                            <th>Giá bán</th>
                            <th>Quán ăn</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="activeProductBody">
                        @if (Model.ActiveProducts != null && Model.ActiveProducts.Any())
                        {
                            foreach (var item in Model.ActiveProducts)
                            {
                                <tr class="product-row" data-shop="@item.Shop?.Name" data-category="@item.Category?.Name">
                                    <td class="ps-4">
                                        <img src="http://localhost:5289/@item.ImageUrl" class="product-thumb rounded shadow-sm view-image" data-img="http://localhost:5289/@item.ImageUrl" />
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark product-name">@item.Name</div>
                                        <div class="small text-muted">@item.Category?.Name</div>
                                    </td>
                                    <td class="fw-bold text-danger">@item.Price.ToString("N0")₫</td>
                                    <td><span class="badge bg-light text-dark border">@(item.Shop?.Name ?? "N/A")</span></td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-light rounded-circle p-2 text-primary shadow-sm mx-1"><i class="fas fa-eye"></i></button>
                                        <button class="btn btn-sm btn-light rounded-circle p-2 text-danger shadow-sm mx-1" title="Khóa món"><i class="fas fa-lock"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted italic">Chưa có món ăn nào đang hoạt động.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Ảnh to -->
<div class="modal fade" id="productImgModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-body p-1 text-center">
                <img id="fullProductImg" src="" class="img-fluid rounded shadow-sm" style="max-height: 80vh;">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3 bg-white p-2 rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Từ chối món -->
<div class="modal fade" id="rejectProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header bg-danger text-white" style="border-radius: 16px 16px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-ban me-2"></i>Từ chối món ăn</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Reject" method="post">
                <input type="hidden" name="id" id="rejectProductId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Lý do từ chối</label>
                        <select name="reason" class="form-select border-0 bg-light py-2" required>
                            <option value="">-- Chọn lý do --</option>
                            <option>Ảnh món ăn không đạt chuẩn (mờ, copy mạng)</option>
                            <option>Giá bán không hợp lý</option>
                            <option>Mô tả món ăn không rõ ràng/phản cảm</option>
                            <option>Món ăn bị cấm kinh doanh</option>
                            <option>Khác...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Ghi chú chi tiết</label>
                        <textarea class="form-control border-0 bg-light" rows="3" placeholder="Nhập lời nhắn gửi đến chủ quán..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger px-4 fw-bold">Xác nhận từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Xem ảnh to
            $('.view-image').click(function() {
                var src = $(this).data('img');
                $('#fullProductImg').attr('src', src);
                new bootstrap.Modal('#productImgModal').show();
            });

            // Mở modal từ chối
            $('.btn-reject-product').click(function() {
                var id = $(this).data('id');
                $('#rejectProductId').val(id);
                new bootstrap.Modal('#rejectProductModal').show();
            });

            // Lọc sản phẩm ở frontend
            function performFilter() {
                var nameVal = $("#searchProductName").val().toLowerCase();
                var shopVal = $("#filterShop").val();
                var catVal = $("#filterCategory").val();

                $(".product-row").each(function() {
                    var row = $(this);
                    var name = row.find(".product-name").text().toLowerCase();
                    var shop = row.data("shop");
                    var cat = row.data("category");

                    var matchName = name.indexOf(nameVal) > -1;
                    var matchShop = shopVal === "" || shop === shopVal;
                    var matchCat = catVal === "" || cat === catVal;

                    if (matchName && matchShop && matchCat) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            $("#btnFilter").click(performFilter);
            $("#searchProductName").on("keyup", performFilter);
        });
    </script>
}

<style>
    .product-thumb-container {
        width: 60px;
        height: 60px;
        overflow: hidden;
        border-radius: 10px;
    }
    .product-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        cursor: pointer;
        transition: transform 0.2s;
    }
    .product-thumb:hover {
        transform: scale(1.1);
    }
    .nav-tabs .nav-link {
        color: #6c757d;
        border: none;
        background: #f8f9fa;
        margin-right: 5px;
    }
    .nav-tabs .nav-link.active {
        color: #fff;
        background-color: var(--accent-color) !important;
        border: none;
    }
    .nav-link:hover:not(.active) {
        background-color: #eee;
    }
</style>
razor
@model LangFood.Shared.ViewModels.ShipperManagementViewModel
@{
    ViewData["Title"] = "Quản lý Người giao hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Quản lý người giao hàng</h1>
</div>

<!-- Tabs Control -->
<ul class="nav nav-tabs border-bottom-0 mb-3" id="shipperTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold px-4 py-2 position-relative" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
            Yêu cầu chờ duyệt
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                @(Model.PendingShippers?.Count ?? 0)
            </span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold px-4 py-2" id="active-tab" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab" style="border-radius: 10px 10px 0 0;">
            Shipper đang hoạt động
        </button>
    </li>
</ul>

<div class="tab-content" id="shipperTabsContent">
    <!-- TAB 1: CHỜ DUYỆT -->
    <div class="tab-pane fade show active" id="pending" role="tabpanel" aria-labelledby="pending-tab">
        <div class="admin-card shadow-sm border-0 bg-white p-3" style="border-radius: 0 0 12px 12px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="m-0 font-weight-bold text-primary">Danh sách Shipper chờ duyệt hồ sơ</h6>
                <button class="btn btn-primary btn-sm px-3 fw-bold shadow-sm" id="btnBulkApprove">
                    <i class="fas fa-check-double me-1"></i> Duyệt hàng loạt
                </button>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">
                                <input class="form-check-input" type="checkbox" id="selectAll">
                            </th>
                            <th>Họ và tên</th>
                            <th>Số điện thoại</th>
                            <th>MSSV (Ghi chú)</th>
                            <th>Ảnh Thẻ SV/CCCD</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PendingShippers != null && Model.PendingShippers.Any())
                        {
                            foreach (var item in Model.PendingShippers)
                            {
                                <tr>
                                    <td><input class="form-check-input shipper-checkbox" type="checkbox" value="@item.Id"></td>
                                    @* SỬA: Lấy FullName và PhoneNumber từ item.User *@
                                    <td class="fw-bold">@(item.User?.FullName ?? "N/A")</td>
                                    <td>@(item.User?.PhoneNumber ?? "N/A")</td>
                                    <td>@item.ShopName</td> @* Đây thường là nơi lưu MSSV gửi từ Android *@
                                    <td>
                                        @* SỬA: Dùng ImageProof thay vì StudentCardImageUrl, và trỏ về port của Backend (5289) *@
                                        <button class="btn btn-sm btn-outline-info view-image-btn rounded-pill px-3" 
                                                data-img-src="@(!string.IsNullOrEmpty(item.ImageProof) ? "http://localhost:5289" + item.ImageProof : "/images/default-card.png")">
                                            <i class="fas fa-image me-1"></i> Xem ảnh
                                        </button>
                                    </td>
                                    <td><span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chờ duyệt</span></td>
                                    <td class="text-end pe-4">
                                        @* Nút Duyệt: Gọi trực tiếp Action Approve *@
                                        <a asp-action="Approve" asp-route-id="@item.Id" 
                                           class="btn btn-sm btn-success rounded-circle p-2 mx-1 shadow-sm" title="Duyệt">
                                            <i class="fas fa-check"></i>
                                        </a>
                                        <button class="btn btn-sm btn-danger rounded-circle p-2 mx-1 shadow-sm btn-reject" 
                                                data-id="@item.Id" title="Từ chối">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted italic">Không có yêu cầu nào đang chờ.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- TAB 2: ĐANG HOẠT ĐỘNG -->
    <div class="tab-pane fade" id="active" role="tabpanel" aria-labelledby="active-tab">
        <div class="admin-card shadow-sm border-0 bg-white p-3" style="border-radius: 0 0 12px 12px;">
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0" id="searchActive" placeholder="Tìm theo tên hoặc SĐT...">
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã SP</th>
                            <th>Họ và tên</th>
                            <th>Số điện thoại</th>
                            <th>MSSV</th>
                            <th>Trạng thái Live</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody id="activeShipperBody">
                        @if (Model.ActiveShippers != null && Model.ActiveShippers.Any())
                        {
                            foreach (var shipper in Model.ActiveShippers)
                            {
                                <tr>
                                    <td class="fw-bold">#SP-@shipper.Id.ToString("D3")</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@(!string.IsNullOrEmpty(shipper.User?.AvatarUrl) ? "http://localhost:5289" + shipper.User?.AvatarUrl : $"https://ui-avatars.com/api/?name={shipper.User?.FullName}&background=random")" class="rounded-circle me-2" width="32" height="32">
                                            <span>@shipper.User?.FullName</span>
                                        </div>
                                    </td>
                                    <td>@shipper.User?.PhoneNumber</td>
                                    <td>@shipper.Mssv</td>
                                    <td>
                                        @if (shipper.IsOnline)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success px-2 py-1"><i class="fas fa-circle me-1 small"></i> Sẵn sàng</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary px-2 py-1"><i class="fas fa-circle me-1 small"></i> Offline</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-light rounded-circle p-2 mx-1 text-primary shadow-sm" title="Xem chi tiết"><i class="fas fa-eye"></i></button>
                                        <a asp-action="ToggleStatus" asp-route-id="@shipper.Id" class="btn btn-sm btn-light rounded-circle p-2 mx-1 text-danger shadow-sm" title="Khóa/Mở khóa">
                                            <i class="fas @(shipper.IsApproved ? "fa-lock" : "fa-lock-open")"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted italic">Chưa có shipper nào đang hoạt động.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Hiển thị ảnh -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">Ảnh Thẻ SV / CCCD</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center p-4">
        <img id="modalImage" src="" alt="ID Image" class="img-fluid rounded shadow-sm" style="max-height: 70vh;" />
      </div>
    </div>
  </div>
</div>

<!-- Modal Từ chối duyệt -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header bg-danger text-white" style="border-radius: 16px 16px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-user-times me-2"></i>Từ chối duyệt Shipper</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Reject" method="post">
                <input type="hidden" name="id" id="rejectId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Lý do từ chối</label>
                        <select class="form-select border-0 bg-light py-2" name="reason">
                            <option value="">-- Chọn lý do --</option>
                            <option value="invalid_img">Ảnh thẻ bị mờ, không rõ mặt</option>
                            <option value="invalid_info">Thông tin cá nhân không khớp</option>
                            <option value="other">Lý do khác...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Ghi chú thêm</label>
                        <textarea class="form-control border-0 bg-light" rows="3" name="note" placeholder="Nhập lời nhắn gửi đến Shipper..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger px-4 fw-bold">Xác nhận từ chối</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Xem ảnh phóng to
            $('.view-image-btn').click(function () {
                var imgSrc = $(this).data('img-src');
                $('#modalImage').attr('src', imgSrc);
                var imageModal = new bootstrap.Modal(document.getElementById('imageModal'));
                imageModal.show();
            });

            // Mở modal từ chối
            $('.btn-reject').click(function() {
                var id = $(this).data('id');
                $('#rejectId').val(id);
                var rejectModal = new bootstrap.Modal(document.getElementById('rejectModal'));
                rejectModal.show();
            });

            // Tìm kiếm Shipper đang hoạt động
            $("#searchActive").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#activeShipperBody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });

            // Chọn tất cả checkbox
            $('#selectAll').change(function () {
                $('.shipper-checkbox').prop('checked', $(this).prop('checked'));
            });
        });
    </script>
}

<style>
    .nav-tabs .nav-link {
        color: #6c757d;
        border: none;
        background: #f8f9fa;
        margin-right: 5px;
    }
    .nav-tabs .nav-link.active {
        color: #fff;
        background-color: #0d6efd !important;
        border: none;
    }
    .bg-success-subtle { background-color: #d1e7dd !important; }
    .bg-secondary-subtle { background-color: #e2e3e5 !important; }
</style>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Làng Food Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LangFoodAdmin.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

    <!-- Sidebar -->
    <aside class="sidebar">
        <a href="/" class="sidebar-brand">
            <i class="fa-solid fa-utensils"></i> Làng Food
        </a>
        <ul class="sidebar-nav">
            <li class="sidebar-item">
                <a class="sidebar-link" asp-controller="Dashboard" asp-action="Index" active-if-match="Dashboard">
                    <i class="fa-solid fa-chart-line"></i> Tổng quan
                </a>
            </li>
            <li class="sidebar-item">
                <a class="sidebar-link" asp-controller="Orders" asp-action="Index" active-if-match="Orders">
                    <i class="fa-solid fa-receipt"></i> Đơn hàng
                </a>
            </li>
            <li class="sidebar-item">
                <a class="sidebar-link" asp-controller="Shippers" asp-action="Index" active-if-match="Shippers">
                    <i class="fa-solid fa-motorcycle"></i> Người giao hàng
                </a>
            </li>
            <li class="sidebar-item">
                <a class="sidebar-link" asp-controller="RoleRequests" asp-action="Index" active-if-match="RoleRequests">
                    <i class="fa-solid fa-store"></i> Duyệt cửa hàng
                </a>
            </li>
            <li class="sidebar-item">
                <a class="sidebar-link" asp-controller="Products" asp-action="Index" active-if-match="Products">
                    <i class="fa-solid fa-burger"></i> Duyệt món ăn
                </a>
            </li>
            <li class="sidebar-item">
                <a class="sidebar-link" asp-controller="Categories" asp-action="Index" active-if-match="Categories">
                    <i class="fa-solid fa-list"></i> Danh mục
                </a>
            </li>
            <li class="sidebar-item">
                <a class="sidebar-link" asp-controller="Buildings" asp-action="Index" active-if-match="Buildings">
                    <i class="fas fa-building"></i> Tòa nhà KTX
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <header class="top-header">
            <div class="header-actions">
                <div class="notification-bell" id="notificationBell">
                    <i class="fa-regular fa-bell"></i>
                    <span class="notification-badge" id="notificationBadge" style="display: none;">0</span>
                </div>
                
                <div class="dropdown">
                    <div class="user-profile" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=F24E1E&color=fff" alt="Admin" class="user-avatar" />
                        <div class="user-info">
                            <span class="user-name">Administrator</span>
                            <span class="user-role">Super Admin</span>
                        </div>
                        <i class="fa-solid fa-chevron-down ms-1" style="font-size: 0.8rem; color: var(--text-secondary);"></i>
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius: var(--border-radius);">
                        <li><a class="dropdown-item py-2" href="#"><i class="fa-regular fa-user me-2"></i> Hồ sơ</a></li>
                        <li><a class="dropdown-item py-2" href="#"><i class="fa-solid fa-gear me-2"></i> Cài đặt</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="#"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-container">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.10/signalr.min.js"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Active link script -->
    <script>
        $(document).ready(function () {
            var path = window.location.pathname.toLowerCase();
            if(path === '/' || path === '/home' || path.startsWith('/dashboard')) {
                $('a[active-if-match="Dashboard"]').addClass('active');
            } else {
                $('.sidebar-link').each(function () {
                    var match = $(this).attr('active-if-match').toLowerCase();
                    if (match && path.includes('/' + match)) {
                        $(this).addClass('active');
                    }
                });
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@{
    ViewData["Title"] = "Tổng quan";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800 fw-bold">Tổng quan hệ thống</h1>
    <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-download fa-sm text-white-50 me-1"></i> Xuất báo cáo
    </a>
</div>

<!-- Thẻ Card thống kê -->
<div class="row gap-4 mb-4" style="flex-wrap: nowrap; overflow-x: auto; padding-bottom: 10px;">
    <!-- Card 1 -->
    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0" style="min-width: 280px;">
        <div class="admin-card border-left-primary h-100 py-2">
            <div class="stat-card">
                <div class="stat-content flex-grow-1">
                    <p class="text-xs font-weight-bold text-primary text-uppercase mb-1" style="font-size: 0.8rem;">Tổng đơn (Tháng)</p>
                    <h3 class="h5 mb-0 font-weight-bold text-gray-800">1,245</h3>
                </div>
                <div class="stat-icon" style="color: #4e73df; background-color: rgba(78, 115, 223, 0.1);">
                    <i class="fas fa-calendar"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2 -->
    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0" style="min-width: 280px;">
        <div class="admin-card border-left-success h-100 py-2">
            <div class="stat-card">
                <div class="stat-content flex-grow-1">
                    <p class="text-xs font-weight-bold text-success text-uppercase mb-1" style="font-size: 0.8rem;">Doanh thu (Tháng)</p>
                    <h3 class="h5 mb-0 font-weight-bold text-gray-800">145,000,000₫</h3>
                </div>
                <div class="stat-icon" style="color: #1cc88a; background-color: rgba(28, 200, 138, 0.1);">
                    <i class="fas fa-dollar-sign"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3 -->
    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0" style="min-width: 280px;">
        <div class="admin-card border-left-info h-100 py-2">
            <div class="stat-card">
                <div class="stat-content flex-grow-1">
                    <p class="text-xs font-weight-bold text-info text-uppercase mb-1" style="font-size: 0.8rem;">Người dùng mới</p>
                    <h3 class="h5 mb-0 font-weight-bold text-gray-800">421</h3>
                </div>
                <div class="stat-icon" style="color: #36b9cc; background-color: rgba(54, 185, 204, 0.1);">
                    <i class="fas fa-users"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 4 -->
    <div class="col-xl-3 col-md-6 mb-4 mb-xl-0" style="min-width: 280px;">
        <div class="admin-card border-left-warning h-100 py-2">
            <div class="stat-card">
                <div class="stat-content flex-grow-1">
                    <p class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="font-size: 0.8rem;">Shipper chờ duyệt</p>
                    <h3 class="h5 mb-0 font-weight-bold text-gray-800">18</h3>
                </div>
                <div class="stat-icon" style="color: #f6c23e; background-color: rgba(246, 194, 62, 0.1);">
                    <i class="fas fa-motorcycle"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bảng Đơn hàng mới nhất -->
<div class="row">
    <div class="col-12">
        <div class="admin-card shadow mb-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="m-0 font-weight-bold" style="color: var(--accent-color);">Đơn hàng mới nhất</h6>
                <a href="/Orders" class="btn btn-sm btn-outline-primary" style="color: var(--accent-color); border-color: var(--accent-color);">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Cửa hàng</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-bold">#LF-001</td>
                            <td>Nguyễn Văn A</td>
                            <td>Cơm Tấm Bà Ba</td>
                            <td class="fw-bold text-danger">45,000₫</td>
                            <td><span class="badge bg-warning text-dark">Chờ xác nhận</span></td>
                            <td>
                                <a href="#" class="btn btn-sm btn-info text-white"><i class="fas fa-eye"></i></a>
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-bold">#LF-002</td>
                            <td>Trần Thị B</td>
                            <td>Trà Sữa KOI</td>
                            <td class="fw-bold text-danger">120,000₫</td>
                            <td><span class="badge bg-info text-dark">Đang giao</span></td>
                            <td>
                                <a href="#" class="btn btn-sm btn-info text-white"><i class="fas fa-eye"></i></a>
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-bold">#LF-003</td>
                            <td>Lê Văn C</td>
                            <td>Bún Bò Huế 39</td>
                            <td class="fw-bold text-danger">65,000₫</td>
                            <td><span class="badge bg-success">Đã giao</span></td>
                            <td>
                                <a href="#" class="btn btn-sm btn-info text-white"><i class="fas fa-eye"></i></a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "Tổng quan";
}

<!-- Thống kê nhanh -->
<div class="row g-4 mb-5">
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 border-bottom-primary">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 fw-semibold text-uppercase fs-7">Tổng doanh thu</p>
                    <h3 class="fs-3 fw-bold mb-0">15,450,000đ</h3>
                </div>
                <div class="icon-shape secondary-bg primary-text rounded-circle p-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-currency-dollar fs-2"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 border-bottom-primary">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 fw-semibold text-uppercase fs-7">Tổng đơn hàng</p>
                    <h3 class="fs-3 fw-bold mb-0">320</h3>
                </div>
                <div class="icon-shape secondary-bg primary-text rounded-circle p-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-bag-check fs-2"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 border-bottom-primary">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 fw-semibold text-uppercase fs-7">Shipper Online</p>
                    <h3 class="fs-3 fw-bold mb-0">24</h3>
                </div>
                <div class="icon-shape secondary-bg primary-text rounded-circle p-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-bicycle fs-2"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card border-0 shadow-sm h-100 border-bottom-primary">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 fw-semibold text-uppercase fs-7">Khách hàng mới</p>
                    <h3 class="fs-3 fw-bold mb-0">15</h3>
                </div>
                <div class="icon-shape secondary-bg primary-text rounded-circle p-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-people fs-2"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bảng Đơn hàng -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Đơn hàng mới nhất</h5>
                <a href="#" class="btn btn-sm btn-outline-primary" style="color: var(--primary-color); border-color: var(--primary-color);">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="ps-4">Mã đơn</th>
                                <th scope="col">Tên sinh viên</th>
                                <th scope="col">Tòa nhà</th>
                                <th scope="col">Tổng tiền</th>
                                <th scope="col">Trạng thái</th>
                                <th scope="col" class="pe-4 text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4 fw-bold primary-text">#LF-1024</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="fw-medium">Nguyễn Văn A</div>
                                    </div>
                                </td>
                                <td><span class="text-muted"><i class="bi bi-geo-alt me-1"></i>KTX Khu B - Tòa BA1</span></td>
                                <td class="fw-semibold">55,000đ</td>
                                <td><span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-clock me-1"></i>Đang chuẩn bị</span></td>
                                <td class="pe-4 text-end">
                                    <button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold primary-text">#LF-1025</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="fw-medium">Trần Thị B</div>
                                    </div>
                                </td>
                                <td><span class="text-muted"><i class="bi bi-geo-alt me-1"></i>KTX Khu B - Tòa BA2</span></td>
                                <td class="fw-semibold">120,000đ</td>
                                <td><span class="badge bg-info text-dark px-3 py-2 rounded-pill"><i class="bi bi-bicycle me-1"></i>Đang giao</span></td>
                                <td class="pe-4 text-end">
                                    <button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold primary-text">#LF-1026</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="fw-medium">Lê Văn C</div>
                                    </div>
                                </td>
                                <td><span class="text-muted"><i class="bi bi-geo-alt me-1"></i>KTX Khu B - Tòa BA3</span></td>
                                <td class="fw-semibold">35,000đ</td>
                                <td><span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check2-circle me-1"></i>Đã giao</span></td>
                                <td class="pe-4 text-end">
                                    <button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold primary-text">#LF-1027</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="fw-medium">Phạm Thị D</div>
                                    </div>
                                </td>
                                <td><span class="text-muted"><i class="bi bi-geo-alt me-1"></i>KTX Khu B - Tòa BA4</span></td>
                                <td class="fw-semibold">85,000đ</td>
                                <td><span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i>Đã hủy</span></td>
                                <td class="pe-4 text-end">
                                    <button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold primary-text">#LF-1028</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="fw-medium">Hoàng Văn E</div>
                                    </div>
                                </td>
                                <td><span class="text-muted"><i class="bi bi-geo-alt me-1"></i>KTX Khu B - Tòa BA5</span></td>
                                <td class="fw-semibold">40,000đ</td>
                                <td><span class="badge bg-secondary px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split me-1"></i>Chờ xác nhận</span></td>
                                <td class="pe-4 text-end">
                                    <button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-eye"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhập số tiền muốn nạp"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Ví dụ: 50000"
            android:inputType="number"
            android:padding="12dp" />

        <!-- Khối hướng dẫn - Mặc định ẩn, hiện khi nhập tiền -->
        <LinearLayout
            android:id="@+id/llSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#1E1E2D"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thực hiện theo hướng dẫn sau để thanh toán:"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Bước 1: Mở ứng dụng Mobile Banking của ngân hàng"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Bước 2: Chọn 'Thanh Toán' và quét mã QR tại hướng dẫn này"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Lưu ý: Không được sửa nội dung chuyển khoản. Việc thay đổi nội dung chuyển khoản sẽ khiến cho giao dịch không được tự động hoàn thành."
                android:textColor="#FFB74D"
                android:textSize="12sp"
                android:fontStyle="italic" />

            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:background="#FFFFFF"
                android:padding="4dp"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Bước 3: Không đóng ứng dụng và đợi Làng Food xử lý trong giây lát"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="* Sau khi chuyển khoản thành công, hãy nhấn 'Nạp ngay' để thông báo cho hệ thống duyệt."
            android:textColor="#757575"
            android:textSize="11sp"
            android:fontStyle="italic" />

    </LinearLayout>
</ScrollView>
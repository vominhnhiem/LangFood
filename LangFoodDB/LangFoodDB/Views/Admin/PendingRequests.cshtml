@{
    ViewData["Title"] = "Quản lý Hồ sơ Đăng ký";
}

<div class="container mt-5">
    <h2>Danh sách hồ sơ chờ duyệt</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Người dùng</th>
                <th>SĐT</th>
                <th>CCCD</th>
                <th>Loại yêu cầu</th>
                <th>Ngày nộp</th>
                <th>Ảnh minh chứng</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody id="requestTableBody">
            <!-- Data will be loaded here via JS -->
        </tbody>
    </table>
</div>

<!-- Modal xem ảnh -->
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ảnh Minh Chứng (CCCD/Thẻ SV)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="Proof" class="img-fluid" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadRequests();
        });

        function loadRequests() {
            $.ajax({
                url: '/api/admin/pending-requests',
                type: 'GET',
                success: function (data) {
                    var tbody = $('#requestTableBody');
                    tbody.empty();

                    if (data.length === 0) {
                        tbody.append('<tr><td colspan="8" class="text-center">Không có hồ sơ nào đang chờ duyệt.</td></tr>');
                        return;
                    }

                    data.forEach(function (req) {
                        var roleText = req.requestType === 1 ? '<span class="badge bg-primary">Seller</span>' : '<span class="badge bg-info">Shipper</span>';
                        var date = new Date(req.createdAt).toLocaleString('vi-VN');
                        
                        var tr = `<tr>
                            <td>${req.id}</td>
                            <td>${req.userName}</td>
                            <td>${req.userPhone}</td>
                            <td>${req.cccdNumber || 'N/A'}</td>
                            <td>${roleText}</td>
                            <td>${date}</td>
                            <td>
                                <button class="btn btn-sm btn-secondary" onclick="showImage('${req.imageProof}')">Xem Ảnh</button>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-success" onclick="processRequest(${req.id}, true)">Duyệt</button>
                                <button class="btn btn-sm btn-danger" onclick="processRequest(${req.id}, false)">Từ chối</button>
                            </td>
                        </tr>`;
                        tbody.append(tr);
                    });
                },
                error: function (err) {
                    console.error("Lỗi tải danh sách hồ sơ:", err);
                    alert("Không thể tải danh sách hồ sơ.");
                }
            });
        }

        function showImage(url) {
            if (!url || url === 'null') {
                alert("Người dùng không đính kèm ảnh minh chứng.");
                return;
            }
            $('#modalImage').attr('src', url);
            var myModal = new bootstrap.Modal(document.getElementById('imageModal'));
            myModal.show();
        }

        function processRequest(id, isApproved) {
            var actionText = isApproved ? "duyệt" : "từ chối";
            if (!confirm(`Bạn có chắc chắn muốn ${actionText} hồ sơ này không?`)) return;

            $.ajax({
                url: `/api/admin/approve-request/${id}`,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify({ isApproved: isApproved }),
                success: function (res) {
                    alert(res.message);
                    loadRequests(); // Tải lại bảng sau khi xử lý
                },
                error: function (err) {
                    alert(err.responseJSON ? err.responseJSON.message : "Đã có lỗi xảy ra.");
                }
            });
        }
    </script>
}
